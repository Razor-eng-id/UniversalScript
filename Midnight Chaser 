if game:GetService("RunService"):IsServer() then

	local Players = game:GetService("Players")
	local ReplicatedStorage = game:GetService("ReplicatedStorage")
	local RunService = game:GetService("RunService")

	local remoteFolder = Instance.new("Folder")
	remoteFolder.Name = "NitroRemotes"
	remoteFolder.Parent = ReplicatedStorage

	local function makeRemote(name)
		local r = Instance.new("RemoteEvent")
		r.Name = name
		r.Parent = remoteFolder
		return r
	end

	makeRemote("ToggleNitro")
	makeRemote("ToggleDrift")
	makeRemote("ToggleNoclip")

	local CONFIG = {
		NITRO_SPEED     = 120,
		NORMAL_SPEED    = 32,
		DRIFT_FRICTION  = 0.1,
		NORMAL_FRICTION = 0.5,
		SEAT_NAME       = "VehicleSeat",
	}

	local playerData = {}

	local function getCarSeat(player)
		local char = player.Character
		if not char then return nil end
		for _, obj in pairs(workspace:GetDescendants()) do
			if obj:IsA("VehicleSeat") and obj.Name == CONFIG.SEAT_NAME then
				if obj.Occupant and obj.Occupant.Parent == char then
					return obj
				end
			end
		end
		return nil
	end

	remoteFolder.ToggleNitro.OnServerEvent:Connect(function(player, isOn)
		playerData[player] = playerData[player] or {}
		playerData[player].nitro = isOn
		local seat = getCarSeat(player)
		if seat then
			seat.MaxSpeed  = isOn and CONFIG.NITRO_SPEED or CONFIG.NORMAL_SPEED
			seat.Torque    = isOn and 150 or 80
			seat.TurnSpeed = isOn and 1.5 or 1
		end
	end)

	remoteFolder.ToggleDrift.OnServerEvent:Connect(function(player, isOn)
		playerData[player] = playerData[player] or {}
		playerData[player].drift = isOn
		local seat = getCarSeat(player)
		if seat then
			local car = seat.Parent
			for _, part in pairs(car:GetDescendants()) do
				if part:IsA("BasePart") then
					local d = (part.CustomPhysicalProperties and part.CustomPhysicalProperties.Density) or 0.9
					part.CustomPhysicalProperties = PhysicalProperties.new(
						d,
						isOn and CONFIG.DRIFT_FRICTION or CONFIG.NORMAL_FRICTION,
						isOn and CONFIG.DRIFT_FRICTION or CONFIG.NORMAL_FRICTION,
						0.5, 0.5
					)
				end
			end
			seat.TurnSpeed = isOn and 3 or ((playerData[player].nitro) and 1.5 or 1)
		end
	end)

	-- Noclip: handled client-side, server hanya terima event log
	remoteFolder.ToggleNoclip.OnServerEvent:Connect(function(player, isOn)
		-- bisa diperluas kalau perlu server action
	end)

	RunService.Heartbeat:Connect(function()
		for player, data in pairs(playerData) do
			if data.nitro then
				local seat = getCarSeat(player)
				if seat and seat.MaxSpeed ~= CONFIG.NITRO_SPEED then
					seat.MaxSpeed = CONFIG.NITRO_SPEED
					seat.Torque   = 150
				end
			end
		end
	end)

	Players.PlayerRemoving:Connect(function(p) playerData[p] = nil end)
	print("[MidnightChasers] Server ✅")

