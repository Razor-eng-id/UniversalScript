-- [[ MIDNIGHT CHASER - ANDROID GOD MODE V3 ]] --
local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/xHeptc/Kavo-UI-Library/main/source.lua"))()
local Window = Library.CreateLib("MIDNIGHT CHASER 🏎️", "Midnight")

-- === CUSTOM ANDROID DRAGGABLE & MINIMIZE ===
local UserInputService = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")

pcall(function()
    local MainGui = CoreGui:FindFirstChild("Midnight") or game:GetService("Players").LocalPlayer.PlayerGui:FindFirstChild("Midnight")
    local MainFrame = MainGui.Main
    
    -- 1. BIAR BISA DI-DRAG DI HP
    local dragging, dragInput, dragStart, startPos
    MainFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = MainFrame.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseMovement) then
            local delta = input.Position - dragStart
            MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        dragging = false
    end)

    -- 2. FITUR MINIMIZE (Floating Button)
    local MinBtn = Instance.new("TextButton")
    MinBtn.Name = "MinButton"
    MinBtn.Parent = MainGui
    MinBtn.Size = UDim2.new(0, 50, 0, 50)
    MinBtn.Position = UDim2.new(0.1, 0, 0.1, 0)
    MinBtn.Text = "MC"
    MinBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    MinBtn.TextColor3 = Color3.fromRGB(0, 255, 150)
    MinBtn.Visible = false
    MinBtn.Draggable = true -- Button bawaan roblox bisa di-drag

    -- Tombol Minimize di Pojok Atas Menu
    local CloseBtn = Instance.new("TextButton")
    CloseBtn.Parent = MainFrame
    CloseBtn.Size = UDim2.new(0, 30, 0, 30)
    CloseBtn.Position = UDim2.new(1, -35, 0, 5)
    CloseBtn.Text = "_"
    CloseBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
    
    CloseBtn.MouseButton1Click:Connect(function()
        MainFrame.Visible = false
        MinBtn.Visible = true
    end)
    
    MinBtn.MouseButton1Click:Connect(function()
        MainFrame.Visible = true
        MinBtn.Visible = false
    end)
end)

-- === TABS ===
local Main = Window:NewTab("Racing")
local Sec = Main:NewSection("Car Mods")

Sec:NewSlider("Top Speed", "GESER KE KANAN!", 2000, 100, function(s)
    pcall(function()
        local car = game.Workspace:FindFirstChild(game.Players.LocalPlayer.Name .. "'s Car") or game.Workspace.Vehicles:FindFirstChild(game.Players.LocalPlayer.Name)
        if car then
            car.Drive.MaxSpeed.Value = s
        end
    end)
end)

Sec:NewButton("Instant Stop", "Klik buat ngerem total", function()
    pcall(function()
        local car = game.Workspace:FindFirstChild(game.Players.LocalPlayer.Name .. "'s Car")
        car.PrimaryPart.Velocity = Vector3.new(0,0,0)
    end)
end)
