task.spawn(function()
    while task.wait(0.1) do
        if NoclipNPC then
            pcall(function()
                for i,v in pairs(workspace.Vehicles:GetChildren()) do
                    if v.Name ~= Player.Name and v.Name ~= Player.Name.."'s Car" then
