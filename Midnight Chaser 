	-- Cari model NPC traffic dan set CanCollide
	local function setTrafficCollision(enabled)
		for _, obj in pairs(workspace:GetDescendants()) do
			-- Filter NPC traffic: biasanya namanya "Car", "Traffic", "NPC", dll
			-- Edit keyword di bawah sesuai nama model traffic di game
			local name = obj.Name:lower()
			if obj:IsA("BasePart") and (
				name:find("traffic") or
				name:find("npc") or
				name:find("vehicle") or
				obj.Parent and obj.Parent.Name:lower():find("traffic")
			) then
				obj.CanCollide = enabled
			end
		end
	end

