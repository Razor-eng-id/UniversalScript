-- == AUTO-STEER & FARM LOGIC ==
local AutoPilot = false
local function GetCar()
    return workspace:FindFirstChild(Player.Name.."'s Car") or workspace.Vehicles:FindFirstChild(Player.Name)
end

RunService.Heartbeat:Connect(function()
    if AutoPilot then
        pcall(function()
            local car = GetCar()
            local speedVal = tonumber(SpeedBox.Text) or 500
            
            -- SENSOR RAYCAST (Kiri & Kanan)
            local root = car.PrimaryPart
            local rayParams = RaycastParams.new()
            rayParams.FilterDescendantsInstances = {car, workspace.Vehicles}
            rayParams.FilterType = Enum.RaycastFilterType.Blacklist

            local leftRay = workspace:Raycast(root.Position, root.CFrame.RightVector * -15, rayParams)
            local rightRay = workspace:Raycast(root.Position, root.CFrame.RightVector * 15, rayParams)

            -- LOGIKA AUTO-STEER (Belok otomatis kalo deket tembok)
            if leftRay then
                root.CFrame = root.CFrame * CFrame.Angles(0, math.rad(-3), 0)
            elseif rightRay then
                root.CFrame = root.CFrame * CFrame.Angles(0, math.rad(3), 0)
            end

            -- JALAN MAJU TERUS (FARMING DUIT)
            root.Velocity = root.CFrame.LookVector * (speedVal / 3.6)
            
            -- INF NITRO & SINKRON KM/H
            car.Drive.MaxSpeed.Value = speedVal / 3.6
            if car:FindFirstChild("Nitro") then car.Nitro.Value = 100 end
        end)
    end
end)

-- == BUTTONS ==
local function AddBtn(txt, pos, callback)
    local b = Instance.new("TextButton", MainFrame)
    b.Size = UDim2.new(0, 160, 0, 35)
    b.Position = pos
    b.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    b.Text = txt; b.TextColor3 = Color3.fromRGB(255, 255, 255)
    Instance.new("UICorner", b).CornerRadius = UDim.new(0, 8)
    b.MouseButton1Click:Connect(callback)
    return b
end

local ApBtn = AddBtn("AUTO-PILOT FARM: OFF", UDim2.new(0, 10, 0, 80), function()
    AutoPilot = not AutoPilot
    MidnightGod.MainFrame.ApBtn.Text = AutoPilot and "AUTO-PILOT: ON" or "AUTO-PILOT: OFF"
end)

AddBtn("INSTANT STOP", UDim2.new(0, 10, 0, 125), function()
