	-- Slider drag logic
	local draggingSlider = false
	local guiTransparency = 0

	local function updateSlider(val)
		val = math.clamp(val, 0, 1)
		guiTransparency = val
		sliderFill.Size = UDim2.new(val, 0, 1, 0)
		sliderKnob.Position = UDim2.new(val, -7, 0.5, -7)
		sliderValLbl.Text = math.floor(val * 100) .. "%"
		-- Apply ke semua frame (kecuali konten teks)
		mainFrame.BackgroundTransparency = val * 0.95
		titleBar.BackgroundTransparency = val * 0.95
		titleFix.BackgroundTransparency = val * 0.95
		for _, f in pairs(content:GetDescendants()) do
			if f:IsA("Frame") and f.Name ~= "Shadow" then
				f.BackgroundTransparency = val * 0.95
			end
		end
	end

